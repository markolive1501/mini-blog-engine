{% extends "base.njk" %}

{% block content %}
  <article class="post-page">
    <div class="post-header">
      <a class="back-link" href="{{ homeUrl }}">← Back to journal</a>
      <p class="eyebrow">Published {{ post.displayDate }}</p>
      <h1>{{ post.title }}</h1>
      <div class="tag-list">
        {% for tag in post.tags %}
          <a class="tag" href="{{ tag.url }}">{{ tag.name }}</a>
        {% endfor %}
      </div>
    </div>
    <div class="post-body">{{ post.html | safe }}</div>
    {% if post.sourceUrl %}
    <div class="post-source">
      <p>📖 <strong>Want to read more?</strong> Check out the original: <a href="{{ post.sourceUrl }}" target="_blank" rel="noopener">{{ post.sourceUrl }}</a></p>
    </div>
    {% endif %}
  </article>
{% endblock %}
