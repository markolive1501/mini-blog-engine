{% extends "base.njk" %}

{% block content %}
  <div class="tag-hero">
    <p class="eyebrow">Knowledge</p>
    <h1>Learn AI &amp; Agents</h1>
    <p class="tag-description">Educational posts that go deeper. Understand the ideas that are reshaping the world.</p>
  </div>

  {% if posts.length %}
  <div class="post-list">
    {% for post in posts %}
    <article class="post-card">
      <div class="post-card-topline">
        <p class="post-meta">{{ post.displayDate }}</p>
      </div>
      <h2><a href="{{ post.url }}">{{ post.title }}</a></h2>
      {% if post.excerpt %}<p class="post-summary">{{ post.excerpt }}</p>{% endif %}
      <div class="post-card-footer">
        <div class="tag-list">
          {% for tag in post.tags %}
            {% if tag.name != 'knowledge' %}
            <a class="tag" href="{{ tag.url }}">{{ tag.name }}</a>
            {% endif %}
          {% endfor %}
        </div>
        {% if post.readingTime %}
        <span class="reading-time">
          <svg viewBox="0 0 24 24" aria-hidden="true" width="12" height="12"><path d="M12 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm-2 9a1 1 0 0 0-1 1v4a1 1 0 1 0 2 0v-1h1a1 1 0 1 0 0-2h-1a3 3 0 0 1-3-3 3 3 0 0 1 3-3h1a1 1 0 1 0 0-2h-1a5 5 0 0 0-5 5 5 5 0 0 0 5 5h1a1 1 0 1 0 0-2h-1a3 3 0 0 1-3-3Z"/></svg>
          {{ post.readingTime }} min read
        </span>
        {% endif %}
        <a class="card-link" href="{{ post.url }}">Read entry</a>
      </div>
    </article>
    {% endfor %}
  </div>
  {% else %}
  <div class="empty-panel">
    <p>No knowledge posts yet. Check back soon.</p>
  </div>
  {% endif %}
{% endblock %}
