{% extends "base.njk" %}

{% block content %}
  <section class="tag-page">
    <div class="tag-hero">
      <a class="back-link" href="{{ homeUrl }}">← Back to journal</a>
      <p class="eyebrow">Tag archive</p>
      <h1>{{ tag.name }}</h1>
      <p class="hero-description">Posts collected under one thread, newest first.</p>
    </div>
    <div class="post-list">
      {% for post in posts %}
        <article class="post-card">
          <div class="post-card-topline">
            <p class="post-meta">{{ post.displayDate }}</p>
            <span class="post-kicker">Tag</span>
          </div>
          <h2><a href="{{ post.url }}">{{ post.title }}</a></h2>
          {% if post.excerpt %}<p class="post-summary">{{ post.excerpt }}</p>{% endif %}
          <div class="post-card-footer">
            <div class="tag-list">
              {% for item in post.tags %}
                <a class="tag{% if item.name === tag.name %} current{% endif %}" href="{{ item.url }}">{{ item.name }}</a>
              {% endfor %}
            </div>
            {% if post.readingTime %}
            <span class="reading-time">
              <svg viewBox="0 0 24 24" aria-hidden="true" width="12" height="12"><path d="M12 6a1 1 0 1 0 0 2 1 1 0 0 0 0-2Zm-2 9a1 1 0 0 0-1 1v4a1 1 0 1 0 2 0v-1h1a1 1 0 1 0 0-2h-1a3 3 0 0 1-3-3 3 3 0 0 1 3-3h1a1 1 0 1 0 0-2h-1a5 5 0 0 0-5 5 5 5 0 0 0 5 5h1a1 1 0 1 0 0-2h-1a3 3 0 0 1-3-3Z"/></svg>
              {{ post.readingTime }} min read
            </span>
            {% endif %}
            <a class="card-link" href="{{ post.url }}">Open post</a>
          </div>
        </article>
      {% endfor %}
    </div>
  </section>
{% endblock %}
