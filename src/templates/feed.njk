<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0">
  <channel>
    <title>{{ site.title | escape }}</title>
    <link>{{ site.url | escape }}</link>
    <description>{{ site.description | escape }}</description>
    {% for post in posts %}
    <item>
      <title>{{ post.title | escape }}</title>
      <link>{{ post.absoluteUrl | escape }}</link>
      <pubDate>{{ post.rssDate }}</pubDate>
      <guid>{{ post.absoluteUrl | escape }}</guid>
      <description><![CDATA[{{ post.html | safe }}]]></description>
    </item>
    {% endfor %}
  </channel>
</rss>
